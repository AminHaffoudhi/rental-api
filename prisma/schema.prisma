generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  RENTER
  OWNER
  BOTH
  ADMIN
}

enum KycStatus {
  PENDING
  SUBMITTED
  APPROVED
  REJECTED
}

enum CodeType {
  EMAIL_VERIFICATION
  PASSWORD_RESET
}

enum BookingStatus {
  PENDING
  CONFIRMED
  REJECTED
  CANCELLED
  PAYMENT_PENDING
  PAID
  PICKUP_SCHEDULED
  IN_TRANSIT
  ACTIVE
  RETURN_SCHEDULED
  RETURNING
  INSPECTING
  COMPLETED
  DISPUTED
  REFUNDED
}

enum DeliveryStatus {
  SCHEDULED
  PICKED_UP
  DELIVERED
  RETURN_SCHEDULED
  RETURN_PICKED_UP
  RETURNED
}

enum PaymentStatus {
  PENDING
  CONFIRMED
  PAYOUT_PENDING
  PAYOUT_SENT
}

enum DisputeStatus {
  OPEN
  RESOLVED_OWNER
  RESOLVED_RENTER
}

enum SupportReportType {
  CONTACT
  REPORT
}

enum SupportReportStatus {
  NEW
  READ
  ARCHIVED
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  password      String?
  image         String?
  coverImage    String?
  bio           String    @default("")
  location      String?
  role          Role      @default(RENTER)
  kycStatus     KycStatus @default(PENDING)
  phone         String?   @unique
  emailVerified Boolean   @default(false)
  canList       Boolean   @default(false)
  /// OneSignal subscription / player id for web push targeting (optional).
  oneSignalPlayerId String?
  blockedAt     DateTime?
  blockedReason String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  equipment          Equipment[]
  bookingsAsRenter   Booking[]          @relation("RenterBookings")
  bookingsAsOwner    Booking[]          @relation("OwnerBookings")
  reviewsGiven       Review[]           @relation("ReviewerReviews")
  reviewsReceived    Review[]           @relation("RevieweeReviews")
  disputesRaised     Dispute[]
  verificationCodes  VerificationCode[]
  kycDocument        KycDocument?
}

model VerificationCode {
  id        String    @id @default(cuid())
  userId    String
  code      String
  type      CodeType
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type])
  @@index([code, type])
}

model KycDocument {
  id           String    @id @default(cuid())
  userId       String    @unique
  documentUrl  String
  documentType String?
  status       KycStatus @default(PENDING)
  adminNote    String?
  reviewedBy   String?
  reviewedAt   DateTime?
  submittedAt  DateTime  @default(now())
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum EquipmentApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

model EquipmentCategory {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String   @default("")
  iconUrl     String   @default("")
  iconKey     String   @default("")
  /// Tailwind classes, e.g. "bg-orange-50 text-orange-700"
  color       String   @default("bg-stone-50 text-stone-600")
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  equipment Equipment[]
}

model Equipment {
  id            String   @id @default(cuid())
  title         String
  description   String
  categoryId    String
  images        String[]
  imageKeys     String[] @default([])
  dailyRate     Float
  weeklyRate    Float?
  depositAmount Float
  deliveryFee   Float
  ownerId         String
  isAvailable     Boolean                  @default(false)
  approvalStatus  EquipmentApprovalStatus  @default(PENDING)
  approvedAt      DateTime?
  rejectionNote   String?
  location        String
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt

  category EquipmentCategory @relation(fields: [categoryId], references: [id])
  owner    User              @relation(fields: [ownerId], references: [id])
  bookings Booking[]
  reviews  Review[]

  @@index([categoryId])
  @@index([approvalStatus])
}

model Booking {
  id            String        @id @default(cuid())
  renterId      String
  ownerId       String
  equipmentId   String
  status        BookingStatus @default(PENDING)
  startDate     DateTime
  endDate       DateTime
  totalPrice    Float
  depositAmount Float
  deliveryFee   Float
  platformFee   Float
  notes         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  renter    User       @relation("RenterBookings", fields: [renterId], references: [id])
  owner     User       @relation("OwnerBookings", fields: [ownerId], references: [id])
  equipment Equipment  @relation(fields: [equipmentId], references: [id])
  delivery  Delivery?
  payment   Payment?
  reviews   Review[]
  dispute   Dispute?

  @@index([equipmentId])
  @@index([renterId])
  @@index([ownerId])
}

model Delivery {
  id           String         @id @default(cuid())
  bookingId    String         @unique
  agentName    String?
  agentPhone   String?
  pickupPhotos String[]
  returnPhotos String[]
  status       DeliveryStatus @default(SCHEDULED)
  deliverySlot DateTime?
  returnSlot   DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  booking Booking @relation(fields: [bookingId], references: [id])
}

model Payment {
  id                      String        @id @default(cuid())
  bookingId               String        @unique
  amount                  Float
  depositAmount           Float
  status                  PaymentStatus @default(PENDING)
  stripeCheckoutSessionId String?       @unique
  stripePaymentIntentId   String?       @unique
  confirmedAt             DateTime?
  payoutSentAt            DateTime?
  confirmedBy             String?
  createdAt               DateTime      @default(now())
  updatedAt               DateTime      @updatedAt

  booking Booking @relation(fields: [bookingId], references: [id])
}

enum ReviewType {
  OWNER
  EQUIPMENT
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

model Review {
  id          String       @id @default(cuid())
  type        ReviewType
  status      ReviewStatus @default(PENDING)
  bookingId   String?
  reviewerId  String
  revieweeId  String
  equipmentId String?
  rating      Int
  comment     String?
  adminNote   String?
  moderatedAt DateTime?
  moderatedBy String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  booking   Booking?    @relation(fields: [bookingId], references: [id])
  reviewer  User        @relation("ReviewerReviews", fields: [reviewerId], references: [id])
  reviewee  User        @relation("RevieweeReviews", fields: [revieweeId], references: [id])
  equipment Equipment?  @relation(fields: [equipmentId], references: [id])

  @@unique([bookingId, reviewerId, type])
  @@unique([reviewerId, equipmentId])
  @@index([status])
  @@index([type])
  @@index([revieweeId])
  @@index([equipmentId])
}

model Dispute {
  id         String        @id @default(cuid())
  bookingId  String        @unique
  raisedById String
  reason     String
  evidence   String[]
  status     DisputeStatus @default(OPEN)
  resolution String?
  resolvedAt DateTime?
  createdAt  DateTime      @default(now())

  booking  Booking @relation(fields: [bookingId], references: [id])
  raisedBy User    @relation(fields: [raisedById], references: [id])
}

model SupportReport {
  id         String              @id @default(cuid())
  type       SupportReportType   @default(CONTACT)
  status     SupportReportStatus @default(NEW)
  firstName  String
  lastName   String
  email      String
  phone      String?
  subject    String?
  message    String
  adminNote  String?
  readAt     DateTime?
  readById   String?
  archivedAt DateTime?
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt

  @@index([status])
  @@index([type])
  @@index([createdAt])
  @@index([email])
}
