# MinIO (S3-compatible) — start server before API, e.g.:
#   docker run -p 9000:9000 -p 9001:9001 -e MINIO_ROOT_USER=minioadmin -e MINIO_ROOT_PASSWORD=minioadmin minio/minio server /data --console-address ":9001"
# If init fails with empty message, try MINIO_ENDPOINT=http://127.0.0.1:9000 (IPv4) instead of localhost.
MINIO_ENDPOINT=http://localhost:9000
# Must match the running MinIO process (see: ps eww $(pgrep minio) | grep MINIO_ROOT)
MINIO_ACCESS_KEY=adsignal
MINIO_SECRET_KEY=adsignal123
MINIO_PUBLIC_BUCKET=rentmarket-public
MINIO_PRIVATE_BUCKET=rentmarket-private
MINIO_REGION=us-east-1
MINIO_PUBLIC_URL=http://localhost:9000/rentmarket-public

UPLOAD_MAX_IMAGE_MB=10
UPLOAD_MAX_DOCUMENT_MB=20

