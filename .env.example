# Copy to .env and fill in values.
# Apply schema: npx prisma db push (or migrate).

NODE_ENV=development
SERVICE_NAME=rental-api
# Optional error tracking (leave unset to disable)
# SENTRY_DSN=
# SENTRY_TRACES_SAMPLE_RATE=0

DATABASE_URL="postgresql://USER@localhost:5432/rental"
# macOS Homebrew Postgres: role is often your macOS username, not "postgres". Example:
# DATABASE_URL="postgresql://jane@localhost:5432/rental"
# With password: postgresql://USER:PASSWORD@localhost:5432/rental

JWT_SECRET="generate_a_long_random_string"
JWT_EXPIRES_IN="7d"
PORT=4000
# Web app origin — used in email links + CORS allowlist
# rental-web Vite dev server (strict port 5174)
CLIENT_URL="http://localhost:5174"
# rental-admin Vite dev server (strict port 5175)
ADMIN_CLIENT_URL=http://localhost:5175
# Optional extra origins (comma-separated). In development, any http://localhost:* is allowed automatically.
# CORS_ORIGINS=http://127.0.0.1:5173
# Browser-reachable MinIO URL if different from MINIO_ENDPOINT (optional)
# MINIO_BROWSER_ENDPOINT=http://127.0.0.1:9000

# Gmail SMTP (2FA + App Password). Required to send verification and notification emails.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your_app_password_here

# MinIO (preferred names — must match your running MinIO server)
MINIO_ENDPOINT=http://127.0.0.1:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
# Or use Docker env names (aliases):
# MINIO_ROOT_USER=minioadmin
# MINIO_ROOT_PASSWORD=minioadmin
MINIO_PUBLIC_BUCKET=rentmarket-public
MINIO_PRIVATE_BUCKET=rentmarket-private
MINIO_REGION=us-east-1
MINIO_PUBLIC_URL=http://127.0.0.1:9000/rentmarket-public

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
# Optional: REDIS_PASSWORD=

# OneSignal (optional — push notifications; leave unset to skip)
# ONESIGNAL_APP_ID=
# ONESIGNAL_REST_API_KEY=

# Stripe (optional — unset disables "Pay with Stripe"; admin can still confirm payments manually)
# Dashboard: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
# Webhook: stripe listen --forward-to localhost:4000/api/payments/webhook
STRIPE_WEBHOOK_SECRET=whsec_...
# Stripe does not charge in TND — use eur or usd in test (amounts use same numbers as TND display)
STRIPE_CURRENCY=eur
